  name = Evgenii Shlikhota
  email = shlikhota@gmail.com

[init]
  defaultBranch = main

[pull]
  rebase = true

[core]
  ignorecase = false
  pager = delta

[delta]
  side-by-side = true
  line-numbers = true
  navigate = true
  syntax-theme = Catppuccin Frappe

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
